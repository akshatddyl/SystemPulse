{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "SystemPulse Real Time Dashboard",
  "uid": "systempulse_dashboard",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": "Prometheus",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "agent_id",
        "options": [],
        "query": "label_values(agent_cpu_usage_percent, agent_id)",
        "refresh": 1,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Servers",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "count(agent_cpu_usage_percent)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ingestion Rate (msg/s)",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(broker_messages_received_total[1m])",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Queue Utilization %",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(broker_queue_size / broker_queue_capacity) * 100",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Anomalies",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(ml_anomalies_detected_total) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Dropped Packets",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "broker_messages_dropped_total",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 6,
      "type": "text",
      "title": "Architecture Flow",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "options": {
        "content": "```\n[Agents (C++)]\n      \u2502\n      \u25bc HTTP JSON\n[Broker Queue (C++)]\n      \u2502\n      \u25bc HTTP JSON\n[FastAPI ML (Python)]\n      \u2502\n      \u25bc Metrics (/metrics)\n[Prometheus & Grafana]\n```",
        "mode": "markdown"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pipeline Throughput (Broker vs ML)",
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(broker_messages_received_total[1m])",
          "legendFormat": "Ingestion Rate (Broker)",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(ml_messages_processed_total[1m])",
          "legendFormat": "Processing Rate (ML)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue Saturation & Backpressure",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "broker_queue_size",
          "legendFormat": "Queue Size",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "broker_queue_capacity",
          "legendFormat": "Max Capacity (Drop-Oldest Trigger)",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Max Capacity (Drop-Oldest Trigger)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Real-Time Z-Score & Anomalies",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ml_current_z_score",
          "legendFormat": "{{agent_id}} - {{metric_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": -3
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Agent CPU & Memory Usage: $agent_id",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": "Prometheus",
      "repeat": "agent_id",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "agent_cpu_usage_percent{agent_id=~\"$agent_id\"}",
          "legendFormat": "CPU % - {{agent_id}}",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "agent_mem_usage_percent{agent_id=~\"$agent_id\"}",
          "legendFormat": "Mem % - {{agent_id}}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    }
  ]
}
